# Magneto X — Lancer toolhead RP2040 CAN fragment
# CAN 250000 for stock Linux Hub (gs_usb 1d50:606f).
# CAN pins: live stock MCU reports RESERVE_PINS_CAN=gpio8,gpio9 → RX=8 TX=9
# Never enable MAGNETO_RELAX_STEPPER_PAST on the toolhead.
#
# Modern Klipper symbol is CONFIG_RPXXXX_CANBUS (not RPXXXX_SELECT_CANBUS).

CONFIG_LOW_LEVEL_OPTIONS=y
CONFIG_MACH_RPXXXX=y
CONFIG_MACH_RP2040=y
CONFIG_RPXXXX_CANBUS=y
CONFIG_CANSERIAL=y
CONFIG_CANBUS_FREQUENCY=250000
CONFIG_RPXXXX_CANBUS_GPIO_RX=8
CONFIG_RPXXXX_CANBUS_GPIO_TX=9
# CONFIG_MAGNETO_RELAX_STEPPER_PAST is not set
