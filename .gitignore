# Reference clones (large / third-party)
peopoly-klipper/
magneto-x-klipper-config/
magneto-x-os-mirror/
magnetox-os-update/
magneto-manager-tool/
/community/
klipper/

# Keep our fork changes only via klipper remote; workspace tracks configs/docs
*.pyc
__pycache__/

# Large Peopoly OS images (store as GitHub Release, not git blobs)
backups/peopoly-os-images/*.img.xz
backups/peopoly-os-images/*.img
backups/**/*.img.gz
backups/**/rootfs.img*
backups/**/disk/*.img.gz
# MainsailOS download cache (multi‑GB)
backups/mainsailos-images/*.img.xz
backups/mainsailos-images/*.img
backups/mainsailos-images/*.partial
# Lab pre-reimage dumps may include serials — keep local unless scrubbed
backups/pre-clean-os-*/magneto_device.cfg
backups/pre-clean-os-*/printer.cfg
backups/pre-clean-os-*/macros.cfg
backups/pre-clean-os-*/printer_data_config.tgz
backups/pre-clean-os-*/moonraker.conf

# 3D models / print files (never commit)
*.stl
*.3mf
*.obj
*.amf
*.step
*.stp
*.gcode
*.gco
*.bgcode
*.ufp

# Secrets / credentials
*.pem
*.key
id_rsa
id_ed25519
*.env
*credentials*
*secrets*
moonraker.secrets
secrets.ini

# Vendor proprietary binaries (obtain privately)
**/Magmotor
**/MagnetoWifiHelper
**/Magmotor.exe

# Large disk/OS images
backups/**/disk/*.img.gz
backups/peopoly-os-images/*.img.xz
backups/peopoly-os-images/*.img
# Live validation captures (may contain UUIDs / LAN info)
docs/validation/live-*
docs/validation/**/*.json
docs/validation/**/*filled*
docs/validation/S3_HARDWARE_REPORT-20*
# Keep templates + README tracked
backups/peopoly-os-images/*.log
backups/**/disk/dd.log
.venv-test/
